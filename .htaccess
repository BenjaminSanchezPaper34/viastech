# ============================================================
# ViasTech — .htaccess Apache (hébergeur classique)
# ============================================================

# ── Encodage / charset ──────────────────────────────────────
AddDefaultCharset UTF-8

# ── Page d'erreur custom ────────────────────────────────────
ErrorDocument 404 /404.html

# ── Compression GZIP ────────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/javascript
  AddOutputFilterByType DEFLATE application/javascript application/json
  AddOutputFilterByType DEFLATE application/xml image/svg+xml
  AddOutputFilterByType DEFLATE font/woff2 font/woff font/ttf
</IfModule>

# ── Cache long pour les assets versionnables ────────────────
<IfModule mod_expires.c>
  ExpiresActive On

  # Images : 1 an
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"

  # Fonts : 1 an
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"

  # CSS / JS : 1 mois (à versionner si modifs fréquentes)
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"

  # HTML : pas de cache fort
  ExpiresByType text/html "access plus 0 seconds"

  # Manifest / sitemap
  ExpiresByType application/manifest+json "access plus 1 day"
  ExpiresByType application/xml "access plus 1 hour"
</IfModule>

# ── Headers de sécurité ─────────────────────────────────────
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(self), interest-cohort=()"
  Header always set Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
</IfModule>

# ── Force HTTPS ─────────────────────────────────────────────
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{HTTPS} !=on
  RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]

  # Pas de www → racine
  RewriteCond %{HTTP_HOST} ^www\.viastech\.fr$ [NC]
  RewriteRule ^(.*)$ https://viastech.fr/$1 [R=301,L]

  # Anciennes URLs WordPress → nouvelles ancres
  RewriteRule ^diagnostic/?$ /#expertise [R=301,L]
  RewriteRule ^mecanique/?$ /#expertise [R=301,L]
  RewriteRule ^boite-automatique/?$ /#expertise [R=301,L]
  RewriteRule ^boite-de-transfert/?$ /#expertise [R=301,L]
  RewriteRule ^double-embrayage/?$ /#expertise [R=301,L]
  RewriteRule ^reprogrammation/?$ /#expertise [R=301,L]
  RewriteRule ^atelier/?$ /#atelier [R=301,L]

  # Pretty URLs : trailing slash sur les dossiers
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteCond %{REQUEST_URI} !/$
  RewriteRule ^(.*)$ /$1/ [R=301,L]
</IfModule>

# ── MIME types complémentaires ──────────────────────────────
<IfModule mod_mime.c>
  AddType image/webp .webp
  AddType application/manifest+json .webmanifest
  AddType font/woff2 .woff2
</IfModule>

# ── Bloque l'accès aux fichiers sensibles ──────────────────
<FilesMatch "\.(md|log|sh|sql|env)$">
  Require all denied
</FilesMatch>
<FilesMatch "^\.(htaccess|git|env)">
  Require all denied
</FilesMatch>
